# ============================================================
# TermuxHost API Server — Environment Variables
# Copy this file to .env and fill in all values.
# ============================================================

# ----- Server -----
PORT=3000
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_change_this_now
JWT_EXPIRES_IN=7d
APP_NAME=TermuxHost
APP_URL=https://yourfrontend.vercel.app

# ----- Neon PostgreSQL -----
# Get from https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ----- Email (Gmail SMTP via App Password) -----
# Enable 2FA on Gmail, then create an App Password:
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ----- Ngrok -----
# Get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken
# Optional: use a fixed ngrok domain (paid plan)
# NGROK_DOMAIN=yourapp.ngrok.app

# ----- NVIDIA AI (Gemma 3n) -----
# Get from https://build.nvidia.com → API Keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=nvidia/gemma-3n-e2b-it

# ----- Projects -----
# Where user project folders are stored (default: ./projects)
# PROJECTS_DIR=/data/data/com.termux/files/home/termuxhost/projects

# ----- CORS -----
# Comma-separated list of allowed frontend origins
# Leave empty to allow all (dev only)
CORS_ORIGINS=https://yourfrontend.vercel.app,https://yourfrontend.github.io

# ----- File limits -----
MAX_FILE_SIZE=5242880
